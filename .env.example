# Required (when using Anthropic provider)
ANTHROPIC_API_KEY=your-api-key-here

# LLM provider: "anthropic" (default) or "ollama"
# LLM_PROVIDER=anthropic

# Ollama base URL (default: http://127.0.0.1:11434/api)
# OLLAMA_BASE_URL=http://127.0.0.1:11434/api

# Database path (default: ./data/schedoodle.db)
# DATABASE_URL=./data/schedoodle.db

# Server port (default: 3000)
# PORT=3000

# Email notifications via Resend
# RESEND_API_KEY=
# NOTIFICATION_EMAIL=
# NOTIFICATION_FROM=

# Email notifications via SMTP
# SMTP_HOST=
# SMTP_PORT=

# Brave Search API key (for web_search tool)
# BRAVE_API_KEY=

# Bearer token authentication — set to require auth on all endpoints
# AUTH_TOKEN=
